# Global Environment Variables for InsightNote (ZeRAG)
# Copy this file to .env and fill in your actual OpenAI API Key

# API Security (Optional, leave empty to disable)
ZERAG_API_KEY=

# LLM Configuration (Default is OpenAI-compatible endpoint v98store)
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_BINDING=openai
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://v98store.com/v1

# Embedding Configuration
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://v98store.com/v1

# Database Credentials
MONGO_URI=mongodb://mongodb:27017
MONGO_DATABASE=cosigmadoc

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

QDRANT_URL=http://qdrant:6333

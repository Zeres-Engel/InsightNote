# ====================================================================
#               InsightNote Environment Configuration Template
# ====================================================================
# Copy this file to '.env' in the root directory (or inside 'backend/')
# and fill in your actual API keys and connection strings.
# ====================================================================

# --------------------------------------------------------------------
# 🔒 Security & Service Settings
# --------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
ZERAG_API_KEY=default_key

# --------------------------------------------------------------------
# 🎛️ SELECT YOUR LLM/EMBEDDING PROVIDER (Choose ONE of the Presets)
# --------------------------------------------------------------------

# --- PRESET 1: v98 Store (Default) ---
LLM_BINDING=openai
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://v98store.com/v1
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://v98store.com/v1
OPENAI_API_KEY=your-v98store-api-key-here

# --- PRESET 2: Google Gemini (Native API via AI Studio) ---
# LLM_BINDING=gemini
# LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=DEFAULT_GEMINI_ENDPOINT
# EMBEDDING_BINDING=gemini
# EMBEDDING_MODEL=text-embedding-004
# EMBEDDING_BASE_URL=DEFAULT_GEMINI_ENDPOINT
# GEMINI_API_KEY=your-google-ai-studio-key-here

# --- PRESET 3: OpenRouter (DeepSeek, Claude, GPT, Gemini) ---
# LLM_BINDING=openai
# LLM_MODEL=google/gemini-2.5-flash
# LLM_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_BINDING=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=https://v98store.com/v1
# OPENAI_API_KEY=your-openrouter-api-key-here

# --- PRESET 4: Ollama (Local LLM & Vector Embeddings) ---
# LLM_BINDING=ollama
# LLM_MODEL=qwen2.5:7b
# EMBEDDING_BINDING=ollama
# EMBEDDING_MODEL=bge-m3:latest

# --------------------------------------------------------------------
# 🎯 Reranker Settings
# --------------------------------------------------------------------
RERANKER_BINDING=jina
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BASE_URL=https://v98store.com/v1/rerank

# --------------------------------------------------------------------
# 🗄️ Infrastructure & Database Connectors
# --------------------------------------------------------------------
# 1. MongoDB (Metadata, Document Status & Cache)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=insightnote

# 2. Neo4j (Knowledge Graph Database)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# 3. Qdrant (High-performance Vector DB)
# - For Docker: http://qdrant:6333
# - For Local: http://localhost:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --------------------------------------------------------------------
# 📁 Storage & Files
# --------------------------------------------------------------------
ZERAG_WORKING_DIR=./rag_storage

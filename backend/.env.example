# ====================================================================
#               InsightNote Environment Configuration Template
# ====================================================================
# Copy this file to '.env' in the root directory (or inside 'backend/')
# and fill in your actual API keys and connection strings.
# ====================================================================

# --------------------------------------------------------------------
# 🔒 Security & Service Settings
# --------------------------------------------------------------------
# System host and port configuration
HOST=0.0.0.0
PORT=8000

# API Key for FastAPI security authorization
ZERAG_API_KEY=default_key

# --------------------------------------------------------------------
# 🧠 LLM (Large Language Model) Settings
# --------------------------------------------------------------------
# Supported bindings: openai | ollama | gemini
LLM_BINDING=openai

# Model selection depending on binding:
# - openai: gpt-4o, gpt-4o-mini, qwen-plus, etc.
# - ollama: qwen2.5:7b, llama3:8b, etc.
# - gemini: gemini-2.5-flash, gemini-2.5-pro, etc.
LLM_MODEL=qwen-plus

# Custom Base URL for LLM Gateway (if using proxies, e.g. v98store, OpenRouter, Vertex AI)
LLM_BASE_URL=https://v98store.com/v1

# OpenAI / Gemini API Key (Required for openai / gemini bindings)
# - For Google Gemini, you can obtain a key at Google AI Studio (https://aistudio.google.com/)
OPENAI_API_KEY=your-openai-or-gemini-key-here

# --------------------------------------------------------------------
# 📐 Embedding & Vector Settings
# --------------------------------------------------------------------
# Supported bindings: openai | ollama | gemini
EMBEDDING_BINDING=openai

# Model selection depending on binding:
# - openai: text-embedding-3-small (1536d), text-embedding-3-large (3072d)
# - ollama: bge-m3:latest (1024d), etc.
# - gemini: text-embedding-004 (768d), gemini-embedding-001 (768d)
EMBEDDING_MODEL=text-embedding-3-small

# Custom Base URL for Embeddings
EMBEDDING_BASE_URL=https://v98store.com/v1

# --------------------------------------------------------------------
# 🎯 Reranker Settings
# --------------------------------------------------------------------
# Supported bindings: jina (or omit to disable)
RERANKER_BINDING=jina
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BASE_URL=https://v98store.com/v1/rerank

# --------------------------------------------------------------------
# 🗄️ Infrastructure & Database Connectors
# --------------------------------------------------------------------
# 1. MongoDB (Metadata, Document Status & Cache)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=insightnote

# 2. Neo4j (Knowledge Graph Database)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# 3. Qdrant (High-performance Vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --------------------------------------------------------------------
# 📁 Storage & Files
# --------------------------------------------------------------------
# Local directory used for staging documents and OCR parser outputs
ZERAG_WORKING_DIR=./rag_storage

# ====================================================================
#               InsightNote Environment Configuration Template
# ====================================================================
# Copy this file to '.env' in the root directory (or inside 'backend/')
# and fill in your actual API keys.
# ====================================================================

# Google API Key (Required for Gemini LLM & Embeddings)
GOOGLE_API_KEY=AIzaSy...

# OpenAI API Key (For OpenAI-compatible proxies, Jina Reranker, etc. - Optional)
OPENAI_API_KEY=sk-...

# Security Authorization Key for FastAPI (e.g., default_key)
ZERAG_API_KEY=default_key

# Database overrides (Optional, leave blank to use config.yaml defaults)
# MONGO_URI=mongodb://localhost:27017
# NEO4J_URI=bolt://localhost:7687
# QDRANT_URL=http://localhost:6333
